{
  "name": "archsentry",
  "version": "0.2.8",
  "description": "Enforce your team's architectural rules on code before merge. Deterministic, config-first, AI-explanation-only.",
  "homepage": "https://github.com/comerade2134/archsentry",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/comerade2134/archsentry.git"
  },
  "bugs": {
    "url": "https://github.com/comerade2134/archsentry/issues"
  },
  "license": "MIT",
  "keywords": [
    "github-app",
    "probot",
    "architecture-governance",
    "linting",
    "static-analysis",
    "ast",
    "semgrep",
    "code-review",
    "ci",
    "developer-tools"
  ],
  "type": "module",
  "bin": {
    "archsentry": "dist/index.js"
  },
  "files": [
    "dist",
    "archsentry.yml.example",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "scan": "tsx src/index.ts scan",
    "dev": "tsx src/index.ts",
    "start": "node --import tsx ./node_modules/probot/bin/probot.js run ./src/app.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "probot": "^14.3.2",
    "simple-git-hooks": "^2.11.1",
    "smee-client": "^5.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
