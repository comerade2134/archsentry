# ArchSentry environment configuration. Copy to `.env` and fill in.
# All values are read by Probot (https://probot.github.io) at startup.

# --- GitHub App credentials (required to run as a GitHub App) ---
# From GitHub → Settings → Developer settings → GitHub Apps → your app.
# (Placeholder — replace with your app's numeric ID. Never commit a real one.)
APP_ID=your-github-app-id

# Webhook secret set when you created the app.
WEBHOOK_SECRET=change-me

# Private key: either paste the PEM contents into PRIVATE_KEY, or point to a
# file via PRIVATE_KEY_PATH (recommended — keep the .pem out of git).
# PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
PRIVATE_KEY_PATH=./private-key.pem

# Webhook proxy for local dev (https://smee.io). Leave empty in production.
WEBHOOK_PROXY_URL=https://smee.io/your-channel

# --- Explanations (all optional; detection is always free) ---
# First match wins: OPENROUTER_API_KEY > OPENAI_API_KEY > OLLAMA_MODEL > template.
# (OpenRouter is checked first so its free tier wins over billed OpenAI.)
# OpenRouter: free tiers available, no card. https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# OpenAI (billed per call). Optional model override (default: gpt-4.1-mini).
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini

# Local Ollama (free, private). https://ollama.com
# OLLAMA_MODEL=
